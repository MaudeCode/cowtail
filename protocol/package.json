{
  "name": "@maudecode/cowtail-protocol",
  "version": "0.1.3",
  "private": true,
  "type": "module",
  "description": "Shared protocol schemas and types for Cowtail services and clients",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "codegen:ios": "bun run ./scripts/generate-ios-openapi.ts"
  },
  "dependencies": {
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@asteasolutions/zod-to-openapi": "^8.1.0",
    "typescript": "^5.9.3"
  }
}
