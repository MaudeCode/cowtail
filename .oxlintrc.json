{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "typescript",
    "unicorn",
    "oxc",
    "react",
    "jsx-a11y"
  ],
  "categories": {
    "correctness": "error"
  },
  "env": {
    "builtin": true
  },
  "settings": {
    "react": {
      "version": "19.0.0"
    }
  },
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "web/convex/_generated/**"
  ],
  "rules": {}
}
