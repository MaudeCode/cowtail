{
  "name": "@maudecode/openclaw-cowtail",
  "version": "0.1.0",
  "private": true,
  "description": "Cowtail channel plugin for OpenClaw",
  "type": "module",
  "openclaw": {
    "extensions": ["./src/index.ts"],
    "setupEntry": "./src/setup-entry.ts",
    "channel": {
      "id": "cowtail",
      "label": "Cowtail",
      "selectionLabel": "Cowtail",
      "detailLabel": "Cowtail",
      "docsLabel": "cowtail",
      "docsPath": "/channels/cowtail",
      "blurb": "Send OpenClaw threads through Cowtail mobile realtime.",
      "systemImage": "message",
      "order": 95
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "bun test src/*.test.ts"
  },
  "dependencies": {
    "@maudecode/cowtail-protocol": "file:../protocol"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.22"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/bun": "^1.3.1",
    "openclaw": "2026.4.22",
    "typescript": "^5.9.3"
  }
}
