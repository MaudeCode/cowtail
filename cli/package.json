{
  "name": "cowtail-cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Cowtail CLI",
  "bin": {
    "cowtail": "./dist/cowtail"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build ./src/cli.ts --compile --outfile ./dist/cowtail --env='COWTAIL_*'",
    "build:js": "bun build ./src/cli.ts --target=node --outfile ./dist/cowtail.js --env='COWTAIL_*'",
    "check": "tsc --noEmit"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "trustedDependencies": [
    "@maudecode/cowtail-protocol"
  ],
  "devDependencies": {
    "@types/node": "^24.7.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@maudecode/cowtail-protocol": "file:../protocol"
  }
}
