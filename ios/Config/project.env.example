# Local iOS app configuration used by ./generate.sh before XcodeGen runs.

COWTAIL_DEVELOPMENT_TEAM=TEAMID1234
COWTAIL_PRODUCT_BUNDLE_IDENTIFIER=com.example.cowtail
COWTAIL_PUBLIC_SITE_URL=https://cowtail.example.com
COWTAIL_CONVEX_QUERY_URL=https://convex-api.example.com/api/query
COWTAIL_HEALTH_SUMMARY_URL=https://cowtail.example.com/actions/api/health
COWTAIL_ALERT_WRITE_URL=https://convex-actions.example.com/api/alerts
COWTAIL_PUSH_REGISTRATION_URL=https://convex-actions.example.com/api/push/register
COWTAIL_PUSH_UNREGISTRATION_URL=https://convex-actions.example.com/api/push/unregister
COWTAIL_ASSOCIATED_DOMAIN_DEBUG=applinks:cowtail.example.com?mode=developer
COWTAIL_ASSOCIATED_DOMAIN_RELEASE=applinks:cowtail.example.com
